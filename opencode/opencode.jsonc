{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode-slim"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": true,
  "permission": {
    "external_directory": {
      "/tmp/**": "allow"
    }
  },
  "mcp": {
    "beads": {
      "type": "local",
      "command": ["/root/.local/beads-venv/bin/beads-mcp"],
      "enabled": true
    },
    "graph-verifier": {
      "type": "local",
      "command": ["/root/.local/graph-verifier-mcp/run.sh"],
      "enabled": true
    }
  }
}
